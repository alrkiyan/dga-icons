{
  "name": "@dga-icons/angular",
  "version": "0.1.0",
  "description": "Angular components for DGA Icons — 4,354 beautifully crafted icons in 9 styles",
  "license": "MIT",
  "author": "Saleh @ Ruman",
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "clean": "rm -rf dist src/icons src/public-api.ts *-rounded *-sharp *-standard"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0"
  },
  "dependencies": {
    "@dga-icons/core": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "~17.3.0",
    "@angular/compiler": "~17.3.0",
    "@angular/compiler-cli": "~17.3.0",
    "@angular/core": "~17.3.0",
    "ng-packagr": "~17.3.0",
    "tslib": "^2.6.2",
    "typescript": "5.4.5"
  },
  "keywords": [
    "icons",
    "angular",
    "svg",
    "components",
    "ui",
    "dga-icons",
    "icon-library"
