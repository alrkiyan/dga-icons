{
  "name": "@dga-icons/js",
  "version": "0.1.1",
  "description": "Vanilla JS components for DGA Icons — 4,354 beautifully crafted icons in 9 styles",
  "license": "MIT",
  "author": "Saleh Alrkiyan (https://isaleh.dev)",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./solid-rounded": {
      "import": {
        "types": "./dist/esm/solid-rounded/index.d.ts",
        "default": "./dist/esm/solid-rounded/index.js"
      }
    },
    "./bulk-rounded": {
      "import": {
        "types": "./dist/esm/bulk-rounded/index.d.ts",
        "default": "./dist/esm/bulk-rounded/index.js"
      }
    },
    "./duotone-rounded": {
      "import": {
        "types": "./dist/esm/duotone-rounded/index.d.ts",
        "default": "./dist/esm/duotone-rounded/index.js"
      }
    },
    "./twotone-rounded": {
      "import": {
        "types": "./dist/esm/twotone-rounded/index.d.ts",
        "default": "./dist/esm/twotone-rounded/index.js"
      }
    },
    "./solid-sharp": {
      "import": {
        "types": "./dist/esm/solid-sharp/index.d.ts",
        "default": "./dist/esm/solid-sharp/index.js"
      }
    },
    "./solid-standard": {
      "import": {
        "types": "./dist/esm/solid-standard/index.d.ts",
        "default": "./dist/esm/solid-standard/index.js"
      }
    },
    "./stroke-sharp": {
      "import": {
        "types": "./dist/esm/stroke-sharp/index.d.ts",
        "default": "./dist/esm/stroke-sharp/index.js"
      }
    },
    "./stroke-standard": {
      "import": {
        "types": "./dist/esm/stroke-standard/index.d.ts",
        "default": "./dist/esm/stroke-standard/index.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist src/icons src/*-rounded src/*-sharp src/*-standard src/index.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@dga-icons/core": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.2"
  },
  "keywords": [
    "icons",
    "javascript",
    "svg",
    "vanilla-js",
    "dga-icons",
    "icon-library"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alrkiyan/dga-icons.git",
    "directory": "packages/js"
  },
  "homepage": "https://github.com/alrkiyan/dga-icons#readme",
  "bugs": {
    "url": "https://github.com/alrkiyan/dga-icons/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
